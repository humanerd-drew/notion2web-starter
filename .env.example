# Notion API Variables
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_sync_database_id_here
NOTION_PARENT_PAGE_ID=your_root_page_id_here

# Cloudflare R2 Variables for Image Hosting
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=your_bucket_name_here
R2_PUBLIC_URL=https://your-public-bucket-url.com

# Hugo Generation
HUGO_CONTENT_DIR=content
